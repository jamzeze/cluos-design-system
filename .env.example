# =============================================================================
# CluOS Hermes — Environment Variables (PLACEHOLDERS ONLY — no real values)
# Copy to .env.local for local dev; populate via: scripts/bw-export-env.sh
# =============================================================================

# --- GitHub Connector ---
GITHUB_TOKEN=ghp_PLACEHOLDER
GITHUB_ORG=jamzeze
GITHUB_DEFAULT_REPO=cluos-design-system

# --- Google Workspace ---
GOOGLE_CLIENT_ID=PLACEHOLDER.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=PLACEHOLDER
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
GOOGLE_REFRESH_TOKEN=PLACEHOLDER
GOOGLE_WORKSPACE_DOMAIN=PLACEHOLDER.com

# --- Gmail ---
GMAIL_DELEGATED_EMAIL=PLACEHOLDER@PLACEHOLDER.com

# --- Google Calendar ---
GOOGLE_CALENDAR_ID=primary

# --- Google Drive ---
GOOGLE_DRIVE_ROOT_FOLDER_ID=PLACEHOLDER

# --- Browserbase ---
BROWSERBASE_API_KEY=PLACEHOLDER
BROWSERBASE_PROJECT_ID=PLACEHOLDER

# --- Firecrawl ---
FIRECRAWL_API_KEY=fc-PLACEHOLDER

# --- Obsidian ---
OBSIDIAN_VAULT_PATH=/path/to/vault
OBSIDIAN_LOCAL_REST_API_KEY=PLACEHOLDER

# --- Apify ---
APIFY_API_TOKEN=apify_api_PLACEHOLDER

# --- YouTube Transcripts ---
YOUTUBE_API_KEY=PLACEHOLDER

# --- Granola / Fathom ---
GRANOLA_API_KEY=PLACEHOLDER
FATHOM_API_KEY=PLACEHOLDER

# --- Telegram Bot (CEO Agent) ---
TELEGRAM_BOT_TOKEN=PLACEHOLDER:PLACEHOLDER
TELEGRAM_ALLOWED_USER_IDS=PLACEHOLDER_YOUR_NUMERIC_ID

# --- Hermes API ---
HERMES_API_URL=https://hermes.cluos.online/api/v1
HERMES_API_KEY=PLACEHOLDER

# --- CEO Agent ---
CEO_AGENT_MODE=approval  # values: auto | approval | dry-run
CEO_AGENT_APPROVAL_REQUIRED=true

# --- Bitwarden ---
BW_CLIENTID=PLACEHOLDER
BW_CLIENTSECRET=PLACEHOLDER
BW_PASSWORD=PLACEHOLDER
BW_SERVER_URL=https://vault.bitwarden.com
