{
  "name": "@cluos/design-system",
  "version": "0.2.0",
  "description": "Cluos brand design system — tokens, assets, UX principles, product patterns, and documentation for all Cluos repositories",
  "main": "tokens/tokens.js",
  "types": "tokens/index.ts",
  "files": [
    "tokens/",
    "brand-assets/",
    "guides/",
    "patterns/",
    "examples/",
    "DESIGN-preview.html",
    "DESIGN.md",
    "DESIGN-WORKFLOW.md",
    "APPLE-INSPIRED-PRODUCT-UX.md",
    "PRODUCT-PATTERNS.md",
    "MIGRATION-AUDIT.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
