#!/usr/bin/env bash
# Non-destructive smoke tests for all Hermes connectors.
# Only reads — never writes, sends, or modifies data.
# Usage:
#   bash scripts/smoke-connectors              # test all
#   bash scripts/smoke-connectors --connector github
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
warn() { echo -e "  ${YELLOW}⚠${NC}  $*"; }
fail() { echo -e "  ${RED}✗${NC} $*"; }

FILTER="${2:-all}"
[[ "${1:-}" == "--connector" ]] && FILTER="${2:-all}"

PASS=0; FAIL=0; SKIP=0

run_test() {
  local name="$1"; local connector_id="$2"; shift 2
  local cmd=("$@")

  [[ "$FILTER" != "all" && "$FILTER" != "$connector_id" ]] && return

  echo ""
  echo "── $name ──"
  if "${cmd[@]}" &>/dev/null; then
    ok "OK"
    ((PASS++))
  else
    fail "FAILED (see manual check: ${cmd[*]})"
    ((FAIL++))
  fi
}

skip_if_missing() {
  local var="$1"; local connector_id="$2"; local name="$3"
  [[ "$FILTER" != "all" && "$FILTER" != "$connector_id" ]] && return 0
  if [[ -z "${!var:-}" ]]; then
    echo ""
    echo "── $name ──"
    warn "Skipped — $var not set"
    ((SKIP++))
    return 1
  fi
  return 0
}

echo "=== Connector Smoke Tests (read-only) ==="
echo "Filter: $FILTER"

# ─── GitHub ──────────────────────────────────────────────────────────────────
if skip_if_missing GITHUB_TOKEN github "GitHub"; then : ; else
  LOGIN=$(curl -sf -H "Authorization: token $GITHUB_TOKEN" \
    https://api.github.com/user 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('login',''))" 2>/dev/null || echo "")
  if [[ -n "$LOGIN" ]]; then
    ok "Authenticated as: $LOGIN"
    ((PASS++))
  else
    fail "GitHub auth failed — check GITHUB_TOKEN"
    ((FAIL++))
  fi
fi

# ─── Google Workspace ────────────────────────────────────────────────────────
if skip_if_missing GOOGLE_CLIENT_ID google-workspace "Google Workspace"; then : ; else
  if [[ -n "${GOOGLE_REFRESH_TOKEN:-}" && -n "${GOOGLE_CLIENT_SECRET:-}" ]]; then
    ACCESS_TOKEN=$(curl -sf -X POST https://oauth2.googleapis.com/token \
      -d "client_id=$GOOGLE_CLIENT_ID" \
      -d "client_secret=$GOOGLE_CLIENT_SECRET" \
      -d "refresh_token=$GOOGLE_REFRESH_TOKEN" \
      -d "grant_type=refresh_token" 2>/dev/null | \
      python3 -c "import sys,json; print(json.load(sys.stdin).get('access_token',''))" 2>/dev/null || echo "")
    if [[ -n "$ACCESS_TOKEN" ]]; then
      EMAIL=$(curl -sf "https://www.googleapis.com/oauth2/v1/userinfo?access_token=$ACCESS_TOKEN" 2>/dev/null | \
        python3 -c "import sys,json; print(json.load(sys.stdin).get('email',''))" 2>/dev/null || echo "")
      if [[ -n "$EMAIL" ]]; then
        ok "Google authenticated"
        ((PASS++))
      else
        fail "Google token valid but no email returned"
        ((FAIL++))
      fi
    else
      fail "Google token refresh failed"
      ((FAIL++))
    fi
  else
    warn "Missing GOOGLE_REFRESH_TOKEN or GOOGLE_CLIENT_SECRET"
    ((SKIP++))
  fi
fi

# ─── Browserbase ─────────────────────────────────────────────────────────────
if skip_if_missing BROWSERBASE_API_KEY browserbase "Browserbase"; then : ; else
  RESULT=$(curl -sf -H "x-bb-api-key: $BROWSERBASE_API_KEY" \
    "https://www.browserbase.com/v1/sessions" 2>/dev/null | \
    python3 -c "import sys,json; d=json.load(sys.stdin); print('ok')" 2>/dev/null || echo "")
  if [[ "$RESULT" == "ok" ]]; then
    ok "Browserbase API reachable"
    ((PASS++))
  else
    fail "Browserbase API unreachable"
    ((FAIL++))
  fi
fi

# ─── Firecrawl ───────────────────────────────────────────────────────────────
if skip_if_missing FIRECRAWL_API_KEY firecrawl "Firecrawl"; then : ; else
  RESULT=$(curl -sf -H "Authorization: Bearer $FIRECRAWL_API_KEY" \
    "https://api.firecrawl.dev/v1/crawl" -X POST \
    -H "Content-Type: application/json" \
    -d '{"url":"https://example.com","limit":1}' 2>/dev/null | \
    python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('success','false'))" 2>/dev/null || echo "false")
  if [[ "$RESULT" == "True" || "$RESULT" == "true" ]]; then
    ok "Firecrawl API authenticated"
    ((PASS++))
  else
    fail "Firecrawl API check failed"
    ((FAIL++))
  fi
fi

# ─── Obsidian ────────────────────────────────────────────────────────────────
if skip_if_missing OBSIDIAN_LOCAL_REST_API_KEY obsidian "Obsidian (local REST API)"; then : ; else
  RESULT=$(curl -sf -H "Authorization: Bearer $OBSIDIAN_LOCAL_REST_API_KEY" \
    "http://localhost:27123/vault/" 2>/dev/null | \
    python3 -c "import sys,json; d=json.load(sys.stdin); print('ok' if 'files' in d else 'fail')" 2>/dev/null || echo "fail")
  if [[ "$RESULT" == "ok" ]]; then
    ok "Obsidian REST API reachable"
    ((PASS++))
  else
    fail "Obsidian REST API unreachable — is the vault open and plugin running?"
    ((FAIL++))
  fi
fi

# ─── Apify ───────────────────────────────────────────────────────────────────
if skip_if_missing APIFY_API_TOKEN apify "Apify (recommended)"; then : ; else
  USERNAME=$(curl -sf "https://api.apify.com/v2/users/me?token=$APIFY_API_TOKEN" 2>/dev/null | \
    python3 -c "import sys,json; print(json.load(sys.stdin).get('data',{}).get('username',''))" 2>/dev/null || echo "")
  if [[ -n "$USERNAME" ]]; then
    ok "Apify authenticated"
    ((PASS++))
  else
    fail "Apify API check failed"
    ((FAIL++))
  fi
fi

# ─── YouTube Transcripts ─────────────────────────────────────────────────────
if skip_if_missing YOUTUBE_API_KEY youtube-transcripts "YouTube Transcripts (recommended)"; then : ; else
  TOTAL=$(curl -sf "https://www.googleapis.com/youtube/v3/videos?part=id&id=dQw4w9WgXcQ&key=$YOUTUBE_API_KEY" 2>/dev/null | \
    python3 -c "import sys,json; print(json.load(sys.stdin).get('pageInfo',{}).get('totalResults',0))" 2>/dev/null || echo "0")
  if [[ "$TOTAL" -ge 1 ]]; then
    ok "YouTube API authenticated"
    ((PASS++))
  else
    fail "YouTube API check failed"
    ((FAIL++))
  fi
fi

# ─── Granola / Fathom ────────────────────────────────────────────────────────
[[ "$FILTER" == "all" || "$FILTER" == "granola-fathom" ]] && {
  echo ""
  echo "── Granola / Fathom (recommended) ──"
  if [[ -z "${GRANOLA_API_KEY:-}" && -z "${FATHOM_API_KEY:-}" ]]; then
    warn "Neither GRANOLA_API_KEY nor FATHOM_API_KEY set — skipping"
    ((SKIP++))
  else
    warn "API smoke test not available — verify manually via respective dashboards"
    ((SKIP++))
  fi
}

# ─── Summary ─────────────────────────────────────────────────────────────────
echo ""
echo "─────────────────────────────────────────"
echo "Results: ${PASS} passed, ${FAIL} failed, ${SKIP} skipped"

if [[ "$FAIL" -gt 0 ]]; then
  echo -e "${RED}Smoke test failed — fix failing connectors before proceeding${NC}"
  exit 1
fi

echo -e "${GREEN}All smoke tests passed${NC}"
