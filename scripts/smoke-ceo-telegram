#!/usr/bin/env bash
# Non-destructive smoke test for Telegram bot connectivity.
# Verifies token validity and bot identity without sending any message.
# Pass --send-test to actually send a test message to TELEGRAM_ALLOWED_USER_IDS.
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
warn() { echo -e "  ${YELLOW}⚠${NC}  $*"; }
fail() { echo -e "  ${RED}✗${NC} $*"; exit 1; }

SEND_TEST=false
[[ "${1:-}" == "--send-test" ]] && SEND_TEST=true

echo "=== Telegram Bot Smoke Test ==="
[[ "$SEND_TEST" == "true" ]] && echo "Mode: send-test (will send a message)"
[[ "$SEND_TEST" == "false" ]] && echo "Mode: read-only (no messages sent)"
echo ""

# ─── 1. Token is set ─────────────────────────────────────────────────────────
if [[ -z "${TELEGRAM_BOT_TOKEN:-}" ]]; then
  fail "TELEGRAM_BOT_TOKEN not set. Load via: source scripts/bw-export-env.sh"
fi
ok "TELEGRAM_BOT_TOKEN is set"

# ─── 2. Validate token with Telegram API ─────────────────────────────────────
RESPONSE=$(curl -sf "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getMe" 2>/dev/null || echo '{"ok":false}')
IS_OK=$(echo "$RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin).get('ok', False))" 2>/dev/null || echo "False")

if [[ "$IS_OK" == "True" ]]; then
  BOT_USERNAME=$(echo "$RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin)['result']['username'])" 2>/dev/null || echo "unknown")
  BOT_ID=$(echo "$RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin)['result']['id'])" 2>/dev/null || echo "unknown")
  ok "Bot authenticated: @$BOT_USERNAME (ID: $BOT_ID)"
else
  fail "Telegram token invalid or API unreachable"
fi

# ─── 3. Check allowed user IDs are set ───────────────────────────────────────
if [[ -n "${TELEGRAM_ALLOWED_USER_IDS:-}" ]]; then
  ID_COUNT=$(echo "$TELEGRAM_ALLOWED_USER_IDS" | tr ',' '\n' | wc -l)
  ok "$ID_COUNT allowed user ID(s) configured"
else
  warn "TELEGRAM_ALLOWED_USER_IDS not set — bot will ignore all users"
fi

# ─── 4. Optional: send test message ──────────────────────────────────────────
if [[ "$SEND_TEST" == "true" ]]; then
  echo ""
  echo "Sending test message..."
  FIRST_ID=$(echo "${TELEGRAM_ALLOWED_USER_IDS:-}" | cut -d',' -f1)
  if [[ -z "$FIRST_ID" ]]; then
    warn "No allowed user ID to send test message to"
  else
    SEND_RESULT=$(curl -sf -X POST \
      "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
      -d "chat_id=$FIRST_ID" \
      -d "text=🤖 CluOS Hermes CEO Agent — smoke test OK ($(date -u +%Y-%m-%dT%H:%M:%SZ))" 2>/dev/null | \
      python3 -c "import sys,json; d=json.load(sys.stdin); print('ok' if d.get('ok') else 'fail')" 2>/dev/null || echo "fail")
    if [[ "$SEND_RESULT" == "ok" ]]; then
      ok "Test message sent successfully"
    else
      fail "Failed to send test message"
    fi
  fi
fi

echo ""
echo -e "${GREEN}Telegram smoke test passed${NC}"
